{
  "ComponentName": "HeaderBlockEventPenalties",
  "VerticalAlignment": "Center",
  "HorizontalAlignment": "Center",
  "BlockType": "stack",
  "Orientation": "Horizontal",
  "Background": "#EEEEEE",
  "Width": "*",
  "Padding": "60,60,60,60",
  "Items": [
    //headerLeft
    {
      "BlockType": "stack",
      "Orientation": "Vertical",
      "Spacing": -10,
      "HorizontalAlignment": "Left",
      "VerticalAlignment": "Center",
      "Items": [
        {
          "Name": "FiA-logo",
          "MarginBottom": 20,
          "BlockType": "image",
          "Height": "175",
          "HorizontalAlignment": "Center",
          "Source": "logotypes/FiA.png"
        }
      ]
    },
    //headerCenter
    {
      "BlockType": "stack",
      "Orientation": "Vertical",
      "Spacing": -10,
      "Width": "*",
      "HorizontalAlignment": "Center",
      "Items": [
        //TTRL Logo
        {
          "BlockType": "stack",
          "VerticalAlignment": "Center",
          "HorizontalAlignment": "Center",
          "MarginBottom": 20,
          "Items": [
            {
              "BlockType": "image",
              "Height": "120",
              "HorizontalAlignment": "Center",
              "Source": "TTRL.2025 .png"
            }
          ]
        },
        //second line - circuit name
        {
          "BlockType": "stack",
          "VerticalAlignment": "Center",
          "HorizontalAlignment": "Center",
          "Items": [
            {
              "BlockType": "text",
              "FontSize": "{HeaderTrackFontSize}",
              "FontName": "{FIAFontBold}",
              "Foreground": "{Season.MainLeagueCategory.Color}",
              "Source": "[{Event.Track.CircuitName, Converter=StringToUpperString} GRAND PRIX]"
            }
          ]
        }
      ]
    },
    //headerRight
    {
      "BlockType": "stack",
      "Orientation": "Vertical",
      "Spacing": -10,
      "HorizontalAlignment": "Center",
      "VerticalAlignment": "Center",
      "Items": [
        {
          "Name": "f1-logo",
          "MarginBottom": 20,
          "BlockType": "image",
          "Height": "75",
          "HorizontalAlignment": "Right",
          "Source": "logotypes/f1_logo.png"
        }
      ]
    }
  ]
}
