            }
          ]
        }
      ]
    },
    //headerRight
    {
      "BlockType": "stack",
      "Orientation": "Vertical",
      "Spacing": -10,
      "HorizontalAlignment": "Center",
      "VerticalAlignment":"Center",
      "MarginLeft" :10,
      "Items": [
        {
          "Name": "f1-logo",
          "MarginBottom": 20,
          "BlockType": "image",
          "Height": "75",
          "HorizontalAlignment": "Right",
          "Source": "logotypes/f1_logo.png"
        }
      ]
    }
  ]
}
