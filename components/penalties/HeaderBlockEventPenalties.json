{
  "ComponentName": "HeaderBlockPenalties",
  "VerticalAlignment": "Center",
  "HorizontalAlignment": "Center",
  "MarginLeft": 10,
  "MarginTop": 25,
  "BlockType": "stack",
  "Orientation": "Horizontal",
  "Items": [
    //headerLeft
    {
      "BlockType": "stack",
      "Orientation": "Vertical",
      "Spacing": -10,
      "HorizontalAlignment": "Left",
      "VerticalAlignment": "Center",
      "Items": [
        {
          "Name": "TTRL-logo",
          "MarginBottom": 20,
          "BlockType": "image",
          "Height": "175",
          "HorizontalAlignment": "Center",
          "Source": "logotypes/TTRL.png"
        }
      ]
    },
    //headerCenter
    {
      "BlockType": "stack",
      "Orientation": "Vertical",
      "Spacing": -10,
      "MarginTop": 25,
      "HorizontalAlignment": "Center",
      "Items": [
        {
          "BlockType": "stack",
          "VerticalAlignment": "Center",
          "HorizontalAlignment": "Center",
          "MarginBottom": 25,
          "Items": [
            {
              "BlockType": "text",
              "VerticalAlignment": "Center",
              "Source": "{Season.LeagueInfo.LeagueName, Converter=StringToUpperString}",
              "FontName": "{TTRLFont}",
              "FontSize": "75",
              "Foreground": "#C9A84C"
            }
          ]
        },
        //second line
        {
          "BlockType": "stack",
          "VerticalAlignment": "Center",
          "HorizontalAlignment": "Center",
          "Items": [
            {
              "BlockType": "text",
              "FontSize": "100",
              "FontName": "{TTRLFontBold}",
              "Foreground": "{Season.MainLeagueCategory.Color}",
              "Source": "[{Penalty.Session.Track.CircuitName, Converter=StringToUpperString} GRAND PRIX]"
            }
          ]
        }
      ]
    },
    //headerRight
    {
      "BlockType": "stack",
      "Orientation": "Vertical",
      "Spacing": -10,
      "HorizontalAlignment": "Center",
      "VerticalAlignment": "Center",
      "MarginLeft": 10,
      "Items": [
        {
          "Name": "f1-logo",
          "MarginBottom": 20,
          "BlockType": "image",
          "Height": "75",
          "HorizontalAlignment": "Right",
          "Source": "logotypes/f1_logo.png"
        }
      ]
    }
  ]
}
