        {
          "Name": "FiA-logo",
          "MarginBottom": 20,
          "BlockType": "image",
          "Height": "175",
          "HorizontalAlignment": "Center",
          "Source": "logotypes/FiA.png"
        }
      ]
    },
    //headerCenter
    {
      "BlockType": "stack",
      "Orientation": "Vertical",
      "Spacing": -10,
      "MarginTop" :25,
      "HorizontalAlignment": "Center",
      "Items": [
        //TTRL Logo
        {
          "BlockType": "stack",
          "VerticalAlignment": "Center",
          "HorizontalAlignment" : "Center",
          "MarginBottom" : 20,
          "Items": [
            {
              "BlockType": "image",
              "Height": "120",
              "HorizontalAlignment": "Center",
              "Source": "TTRL.2025 .png"
            }
          ]
        },
        //second line - circuit name
        {
          "BlockType": "stack",
          "VerticalAlignment": "Center",
          "HorizontalAlignment" : "Center",
          "Items": [
            {
              "BlockType": "text",
              "FontSize": 100,
              "FontName": "{FIAFontBold}",
              "Foreground": "#111111",
