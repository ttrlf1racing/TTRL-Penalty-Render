{
  "ComponentName": "HeaderBlockEventPenalties",
  "VerticalAlignment": "Center",
  "HorizontalAlignment":"Center",
  "MarginLeft": 10,
  "MarginTop" : 25,
  "BlockType": "stack",
  "Orientation": "Horizontal",
  "Background": "#EEEEEE",
  "Padding": "20,20,20,20",
  "Items": [
    //headerLeft
    {
      "BlockType": "stack",
      "Orientation": "Vertical",
      "Spacing": -10,
      "HorizontalAlignment": "Left",
