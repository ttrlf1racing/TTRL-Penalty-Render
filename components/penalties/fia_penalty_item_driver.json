{
  "ComponentName": "fia_penalty_item_driver",
  "BlockType": "stack",
  "Padding": "0,0,0,0",
  "Orientation": "Vertical",
  "Spacing": 0,
  "Items": [
    {
      "BlockType": "stack",
      "Background": "#0D0D1A",
      "Padding": "30,30,30,30",
      "Orientation": "Vertical",
      "Items": [
        // Red Accent Bar
        {
          "BlockType": "stack",
          "Background": "#C0132B",
          "Height": 8,
          "MarginBottom": 20
        },
        // Header info
        {
          "BlockType": "stack",
          "Orientation": "Horizontal",
          "MarginBottom": 15,
          "Items": [
            {
              "BlockType": "text",
              "Source": "PENALTY #<{Penalty.PenaltyId}>",
              "FontName": "{FIAFontBold}",
              "FontSize": 20,
              "Foreground": "#C9A84C"
            },
            {
              "BlockType": "text",
              "Source": "<{Penalty.Date, Converter=DateToDayOfMonth}> <{Penalty.Date, Converter=DateToMonthInWords}>",
              "FontName": "{FIAFont}",
              "FontSize": 20,
              "Foreground": "#888888",
              "HorizontalAlignment": "Right"
            }
          ]
        },
        // Offense
        {
          "BlockType": "text",
          "Source": "<{Penalty.Offense, Converter=StringToUpperString}>",
          "FontName": "{FIAFontBold}",
          "FontSize": 32,
          "Foreground": "#F0F0F0",
          "MarginBottom": 5
        },
        {
          "BlockType": "text",
          "Source": "<{Penalty.Session.SessionType}> - <{Penalty.Session.Track.CircuitName}>",
          "FontName": "{FIAFont}",
          "FontSize": 24,
          "Foreground": "#C9A84C",
          "MarginBottom": 25
        },
        // Divider
        {
          "BlockType": "stack",
          "Background": "#333333",
          "Height": 1,
          "MarginBottom": 25
        },
        // Decision and Verdict
        {
          "BlockType": "stack",
          "Orientation": "Vertical",
          "Items": [
            {
              "BlockType": "stack",Modern TTRL Layout for driver penalty items: Dark mode, vertical stack, red accent bar
              "Orientation": "Horizontal",
              "MarginBottom": 15,
              "Items": [
                 { "BlockType": "text", "Source": "DECISION:", "FontName": "{FIAFontBold}", "FontSize": 20, "Foreground": "#C0132B", "Width": 150 },
                 {
                   "BlockType": "stack",
                   "Orientation": "Horizontal",
                   "Spacing": 20,
                   "Items": [
                      { "BlockType": "text", "Source": "<{Penalty.PenaltySeconds}>s Penalty", "RenderIf": "<{Penalty.PenaltySeconds, Converter=NumberIsNotZero}>", "FontName": "{FIAFontBold}", "FontSize": 20, "Foreground": "#F0F0F0" },
                      { "BlockType": "text", "Source": "<{Penalty.PenaltyPoints}> Pts", "RenderIf": "<{Penalty.PenaltyPoints, Converter=NumberIsNotZero}>", "FontName": "{FIAFontBold}", "FontSize": 20, "Foreground": "#F0F0F0" },
                      { "BlockType": "text", "Source": "NFA", "RenderIf": "<{Penalty.IsNoPunishment}>", "FontName": "{FIAFontBold}", "FontSize": 20, "Foreground": "#F0F0F0" }
                   ]
                 }
              ]
            },
            {
              "BlockType": "text",
              "Source": "<{Penalty.Verdict}>",
              "FontName": "{FIAFont}",
              "FontSize": 18,
              "Foreground": "#D0D0D0",
              "MaxWidth": 1400,
              "TextOptions": { "Wrap": true }
            }
          ]
        }
      ]
    },
    // Spacing between items
    {
       "BlockType": "stack",
       "Height": 20
    }
  ]
}
