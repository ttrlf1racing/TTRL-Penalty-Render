{
  "ComponentName": "fia_penalty_item_driver",
  "BlockType": "stack",
  "Padding": "0,0,0,0",
  "Orientation": "Vertical",
  "Spacing": 0,
  "Items": [
    {
      "BlockType": "stack",
      "Background": "#FFFFFF",
      "Padding": "60,60,60,60",
      "Orientation": "Vertical",
      "Items": [
        // Red Accent Bar
        {
          "BlockType": "stack",
          "Background": "#C0132B",
          "Height": 12,
          "MarginBottom": 40
        },
        // Header info
        {
          "BlockType": "stack",
          "Orientation": "Horizontal",
          "MarginBottom": 30,
          "Items": [
            {
              "BlockType": "text",
              "Source": "PENALTY #<{Penalty.PenaltyId}>",
              "FontName": "Arial",
              "FontSize": 32,
              "Foreground": "#C9A84C"
            },
            {
              "BlockType": "text",
              "Source": "<{Penalty.Date, Converter=DateToDayOfMonth}> <{Penalty.Date, Converter=DateToMonthInWords}>",
              "FontName": "Arial",
              "FontSize": 32,
              "Foreground": "#888888",
              "HorizontalAlignment": "Right"
            }
          ]
        },
        // Offense
        {
          "BlockType": "text",
          "Source": "<{Penalty.Offense, Converter=StringToUpperString}>",
          "FontName": "Arial",
          "FontSize": 48,
          "Foreground": "#111111",
          "MarginBottom": 10
        },
        {
          "BlockType": "text",
          "Source": "<{Penalty.Session.SessionType}> - <{Penalty.Session.Track.CircuitName}>",
          "FontName": "Arial",
          "FontSize": 36,
          "Foreground": "#C9A84C",
          "MarginBottom": 40
        },
        // Decision and Verdict
        {
          "BlockType": "stack",
          "Orientation": "Vertical",
          "Items": [
            {
              "BlockType": "stack",
              "Orientation": "Horizontal",
              "MarginBottom": 30,
              "Items": [
                 { "BlockType": "text", "Source": "DECISION:", "FontName": "Arial", "FontSize": 32, "Foreground": "#C0132B", "Width": 250 },
                 {
                   "BlockType": "stack",
                   "Orientation": "Horizontal",
                   "Spacing": 40,
                   "Items": [
                      { "BlockType": "text", "Source": "<{Penalty.PenaltySeconds}>s Penalty", "RenderIf": "<{Penalty.PenaltySeconds, Converter=NumberIsNotZero}>", "FontName": "Arial", "FontSize": 32, "Foreground": "#111111" },
                      { "BlockType": "text", "Source": "<{Penalty.PenaltyPoints}> Pts", "RenderIf": "<{Penalty.PenaltyPoints, Converter=NumberIsNotZero}>", "FontName": "Arial", "FontSize": 32, "Foreground": "#111111" },
                      { "BlockType": "text", "Source": "NFA", "RenderIf": "<{Penalty.IsNoPunishment}>", "FontName": "Arial", "FontSize": 32, "Foreground": "#111111" }
                   ]
                 }
              ]
            },
            // Heading for Details
            { "BlockType": "text", "Source": "DETAILS", "FontName": "Arial", "FontSize": 28, "Foreground": "#C9A84C", "MarginBottom": 15 },
            {
              "BlockType": "text",
              "Source": "<{Penalty.Verdict}>",
              "FontName": "Arial",
              "FontSize": 36,
              "Foreground": "#333333",
              "MaxWidth": 2800,
              "TextOptions": { "Wrap": true },
              "MarginBottom": 40
            },
            // Heading for Verdict
            { "BlockType": "text", "Source": "VERDICT", "FontName": "Arial", "FontSize": 28, "Foreground": "#C9A84C", "MarginBottom": 15 },
            {
              "BlockType": "text",
              "Source": "<{Penalty.Verdict}>",
              "FontName": "Arial",
              "FontSize": 36,
              "Foreground": "#333333",
              "MaxWidth": 2800,
              "TextOptions": { "Wrap": true }
            }
          ]
        }
      ]
    },
    // Spacing between items
    {
       "BlockType": "stack",
       "Height": 40
    }
  ]
}
