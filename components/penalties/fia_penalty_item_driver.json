{
  "ComponentName": "fia_penalty_item_driver",
  "BlockType": "stack",
  "Padding": "0,0,0,0",
  "Orientation": "Vertical",
  "Spacing": 0,
  "Items": [
    {
      "BlockType": "stack",
      "Background": "#EEEEEE",
      "Padding": "60,60,60,60",
      "Orientation": "Vertical",
      "Items": [
        // Red Accent Bar
        {
          "BlockType": "stack",
          "Background": "#C0132B",
          "Height": 12,
          "MarginBottom": 40
        },
        // Header info
        {
          "BlockType": "stack",
          "Orientation": "Horizontal",
          "MarginBottom": 30,
          "Items": [
            {
              "BlockType": "text",
              "Source": "PENALTY <{Penalty.PenaltyId}>",
              "FontName": "Arial",
              "FontSize": 32,
              "Foreground": "#C0132B"
            },
            {
              "BlockType": "text",
              "Source": "<{Penalty.Date, Converter=DateToDayOfMonth}> <{Penalty.Date, Converter=DateToMonthInWords}>",
              "FontName": "Arial",
              "FontSize": 32,
              "Foreground": "#888888",
              "HorizontalAlignment": "Right",
              "MarginLeft": 40
            }
          ]
        },
        {
          "BlockType": "text",
          "Source": "<{Penalty.Offense, Converter=StringToUpperString}>",
          "FontName": "Arial",
          "FontSize": 48,
          "Foreground": "#000000",
          "MarginBottom": 10
        },
        {
          "BlockType": "text",
          "Source": "<{Penalty.Session.SessionType}> - <{Penalty.Session.Track.CircuitName}>",
          "FontName": "Arial",
          "FontSize": 36,
          "Foreground": "#C9A84C",
          "MarginBottom": 40
        },
        // Decision row
        {
          "BlockType": "stack",
          "Orientation": "Horizontal",
          "MarginBottom": 40,
          "Items": [
            {
              "BlockType": "text",
              "Source": "DECISION: ",
              "FontName": "Arial",
              "FontSize": 36,
              "Foreground": "#C0132B"
            },
            {
              "BlockType": "text",
              "RenderIf": "<{Penalty.PenaltySeconds, Converter=NumberIsNotZero}>",
              "Source": "• <{Penalty.PenaltySeconds}> SEC ",
              "FontName": "Arial",
              "FontSize": 36,
              "Foreground": "#000000"
            },
            {
              "BlockType": "text",
              "RenderIf": "<{Penalty.PenaltyPoints, Converter=NumberIsNotZero}>",
              "Source": "• <{Penalty.PenaltyPoints}> PTS ",
              "FontName": "Arial",
              "FontSize": 36,
              "Foreground": "#000000"
            },
            {
              "BlockType": "text",
              "RenderIf": "<{Penalty.IsNoPunishment}>",
              "Source": "NO FURTHER ACTION",
              "FontName": "Arial",
              "FontSize": 36,
              "Foreground": "#000000"
            }
          ]
        },
        // Details paragraph
        {
          "BlockType": "stack",
          "Orientation": "Vertical",
          "Width": "*",
          "MarginBottom": 40,
          "Items": [
            {
              "BlockType": "text",
              "Source": "DETAILS",
              "FontName": "Arial",
              "FontSize": 32,
              "Foreground": "#C9A84C",
              "MarginBottom": 10
            },
            {
              "BlockType": "text",
              "Source": "<{Penalty.Description}>",
              "FontName": "Arial",
              "FontSize": 36,
              "Foreground": "#444444",
              "Width": "*",
              "TextOptions": { "Wrap": true }
            }
          ]
        },
        // Verdict paragraph
        {
          "BlockType": "stack",
          "Orientation": "Vertical",
          "Width": "*",
          "Items": [
            {
              "BlockType": "text",
              "Source": "VERDICT",
              "FontName": "Arial",
              "FontSize": 32,
              "Foreground": "#C9A84C",
              "MarginBottom": 10
            },
            {
              "BlockType": "text",
              "Source": "<{Penalty.Verdict}>",
              "FontName": "Arial",
              "FontSize": 36,
              "Foreground": "#444444",
              "Width": "*",
              "TextOptions": { "Wrap": true }
            }
          ]
        },
        { "BlockType": "stack", "Height": 40 }
      ]
    }
  ]
}
