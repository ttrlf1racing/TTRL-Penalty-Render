{
  "ComponentName": "fia_penalty_item",
  "BlockType": "stack",
  "Padding": "0,0,0,0",
  "Orientation": "Vertical",
  "Spacing": 0,
  "Items": [
    {
      "BlockType": "stack",
      "Background": "#FFFFFF",
      "Padding": "80,80,80,80",
      "Orientation": "Vertical",
      "Items": [
        // Top Red Bar
        {
          "BlockType": "stack",
          "Background": "#C0132B",
          "Height": 20,
          "MarginBottom": 60
        },
        // Meta Info
        {
          "BlockType": "stack",
          "Orientation": "Horizontal",
          "MarginBottom": 40,
          "Items": [
            {
              "BlockType": "text",
              "Source": "DOCUMENT #<{Penalty.PenaltyId}>",
              "FontName": "Arial",
              "FontSize": 36,
              "Foreground": "#C9A84C"
            },
            {
              "BlockType": "text",
              "Source": "<{Penalty.Date, Converter=DateToDayOfMonth}> <{Penalty.Date, Converter=DateToMonthInWords}> <{Penalty.Date, Converter=DateToYear}>",
              "FontName": "Arial",
              "FontSize": 36,
              "Foreground": "#888888",
              "HorizontalAlignment": "Right"
            }
          ]
        },
        // Verdict Title
        {
          "BlockType": "text",
          "Source": "OFFICIAL STEWARDS VERDICT",
          "FontName": "Arial",
          "FontSize": 72,
          "Foreground": "#111111",
          "MarginBottom": 20
        },
        {
          "BlockType": "text",
          "Source": "<{Penalty.Session.SessionType}> - <{Penalty.Offense}>",
          "FontName": "Arial",
          "FontSize": 48,
          "Foreground": "#C9A84C",
          "MarginBottom": 60
        },
        // Grid Details
        {
          "BlockType": "stack",
          "Spacing": 40,
          "Items": [
            {
              "BlockType": "stack", "Orientation": "Horizontal",
              "Items": [
                { "BlockType": "text", "Source": "DRIVER", "FontName": "Arial", "FontSize": 36, "Foreground": "#C0132B", "Width": 400 },
                { "BlockType": "text", "Source": "#<{Penalty.Driver.RaceNumber}> <{Penalty.Driver.Name}>", "FontName": "Arial", "FontSize": 36, "Foreground": "#111111" }
              ]
            },
            {
              "BlockType": "stack", "Orientation": "Horizontal",
              "Items": [
                { "BlockType": "text", "Source": "COMPETITOR", "FontName": "Arial", "FontSize": 36, "Foreground": "#C0132B", "Width": 400 },
                { "BlockType": "text", "Source": "<{Penalty.Team.FullName}>", "FontName": "Arial", "FontSize": 36, "Foreground": "#111111" }
              ]
            },
            {
              "BlockType": "stack", "Orientation": "Horizontal",
              "Items": [
                { "BlockType": "text", "Source": "DECISION", "FontName": "Arial", "FontSize": 36, "Foreground": "#C0132B", "Width": 400 },
                {
                  "BlockType": "stack",
                  "Items": [
                    { "BlockType": "text", "Source": "<{Penalty.PenaltySeconds}>s Time Penalty", "RenderIf": "<{Penalty.PenaltySeconds, Converter=NumberIsNotZero}>", "FontName": "Arial", "FontSize": 36, "Foreground": "#111111" },
                    { "BlockType": "text", "Source": "<{Penalty.PenaltyPoints}> Penalty Points", "RenderIf": "<{Penalty.PenaltyPoints, Converter=NumberIsNotZero}>", "FontName": "Arial", "FontSize": 36, "Foreground": "#111111" },
                    { "BlockType": "text", "Source": "No Further Action", "RenderIf": "<{Penalty.IsNoPunishment}>", "FontName": "Arial", "FontSize": 36, "Foreground": "#111111" }
                  ]
                }
              ]
            }
          ]
        },
        // Details Paragraph
        {
          "BlockType": "stack",
          "MarginTop": 80,
          "Items": [
            { "BlockType": "text", "Source": "DETAILS", "FontName": "Arial", "FontSize": 32, "Foreground": "#C9A84C", "MarginBottom": 20 },
            {
              "BlockType": "text",
              "Source": "<{Penalty.Verdict}>", // Using Verdict as proxy for details if no separate field exists, or user can provide
              "FontName": "Arial",
              "FontSize": 40,
              "Foreground": "#333333",
              "MaxWidth": 2800,
              "TextOptions": { "Wrap": true }
            }
          ]
        },
        // Verdict Paragraph
        {
          "BlockType": "stack",
          "MarginTop": 60,
          "Items": [
            { "BlockType": "text", "Source": "STEWARDS VERDICT", "FontName": "Arial", "FontSize": 32, "Foreground": "#C9A84C", "MarginBottom": 20 },
            {
              "BlockType": "text",
              "Source": "<{Penalty.Verdict}>",
              "FontName": "Arial",
              "FontSize": 40,
              "Foreground": "#333333",
              "MaxWidth": 2800,
              "TextOptions": { "Wrap": true }
            }
          ]
        }
      ]
    }
  ]
}
