{
  "ComponentName": "fia_penalty_item",
  "BlockType": "stack",
  "Padding": "0,0,0,0",
  "Orientation": "Vertical",
  "Spacing": 0,
  "Items": [
    {
      "BlockType": "stack",
      "Background": "#C8C8C8",
      "Padding": "80,80,80,80",
      "Orientation": "Vertical",
      "Items": [
        // Top Red Bar
        {
          "BlockType": "stack",
          "Background": "#C0132B",
          "Height": 20,
          "MarginBottom": 60
        },
        // Meta Info
        {
          "BlockType": "stack",
          "Orientation": "Horizontal",
          "MarginBottom": 40,
          "Items": [
            {
              "BlockType": "text",
              "Source": "DOCUMENT #<{Penalty.PenaltyId}>",
              "FontName": "Arial",
              "FontSize": 36,
              "Foreground": "#C9A84C"
            },
            {
              "BlockType": "text",
              "Source": "<{Penalty.Date, Converter=DateToDayOfMonth}> <{Penalty.Date, Converter=DateToMonthInWords}> <{Penalty.Date, Converter=DateToYear}>",
              "FontName": "Arial",
              "FontSize": 36,
              "Foreground": "#888888",
              "HorizontalAlignment": "Right"
            }
          ]
        },
        // Verdict Title
        {
          "BlockType": "text",
          "Source": "OFFICIAL STEWARDS VERDICT",
          "FontName": "Arial",
          "FontSize": 72,
          "Foreground": "#111111",
          "MarginBottom": 20
        },
        {
          "BlockType": "text",
          "Source": "<{Penalty.Session.SessionType}> - <{Penalty.Offense}>",
          "FontName": "Arial",
          "FontSize": 48,
          "Foreground": "#C9A84C",
          "MarginBottom": 60
        },
        // Grid Details - Driver / Team / Decision evenly spaced across page
        {
          "BlockType": "stack",
          "Orientation": "Horizontal",
          "MarginBottom": 60,
          "Items": [
            // Driver column
            {
              "BlockType": "stack",
              "Orientation": "Vertical",
              "Width": 900,
              "Items": [
                {
                  "BlockType": "text",
                  "Source": "DRIVER",
                  "FontName": "Arial",
                  "FontSize": 32,
                  "Foreground": "#C0132B",
                  "MarginBottom": 8
                },
                {
                  "BlockType": "text",
                  "Source": "#<{Penalty.Driver.RaceNumber}> <{Penalty.Driver.Name}>",
                  "FontName": "Arial",
                  "FontSize": 36,
                  "Foreground": "#111111"
                }
              ]
            },
            // Team column
            {
              "BlockType": "stack",
              "Orientation": "Vertical",
              "Width": 900,
              "Items": [
                {
                  "BlockType": "text",
                  "Source": "TEAM",
                  "FontName": "Arial",
                  "FontSize": 32,
                  "Foreground": "#C0132B",
                  "MarginBottom": 8
                },
                {
                  "BlockType": "text",
                  "Source": "<{Penalty.Team.FullName}>",
                  "FontName": "Arial",
                  "FontSize": 36,
                  "Foreground": "#111111"
                }
              ]
            },
            // Decision column
            {
              "BlockType": "stack",
              "Orientation": "Vertical",
              "Width": 900,
              "Items": [
                {
                  "BlockType": "text",
                  "Source": "DECISION",
                  "FontName": "Arial",
                  "FontSize": 32,
                  "Foreground": "#C0132B",
                  "MarginBottom": 8
                },
                {
                  "BlockType": "text",
                  "Source": "<{Penalty.PenaltySeconds}>s Time Penalty",
                  "RenderIf": "<{Penalty.PenaltySeconds, Converter=NumberIsNotZero}>",
                  "FontName": "Arial",
                  "FontSize": 36,
                  "Foreground": "#111111"
                },
                {
                  "BlockType": "text",
                  "Source": "<{Penalty.PenaltyPoints}> Penalty Points",
                  "RenderIf": "<{Penalty.PenaltyPoints, Converter=NumberIsNotZero}>",
                  "FontName": "Arial",
                  "FontSize": 36,
                  "Foreground": "#111111"
                },
                {
                  "BlockType": "text",
                  "Source": "No Further Action",
                  "RenderIf": "<{Penalty.IsNoPunishment}>",
                  "FontName": "Arial",
                  "FontSize": 36,
                  "Foreground": "#111111"
                }
              ]
            }
          ]
        },
        // Details Paragraph
        {
          "BlockType": "stack",
          "MarginTop": 60,
          "Orientation": "Vertical",
          "Items": [
            {
              "BlockType": "text",
              "Source": "DETAILS",
              "FontName": "Arial",
              "FontSize": 32,
              "Foreground": "#C9A84C",
              "HorizontalAlignment": "Left",
              "MarginBottom": 12
            },
            {
              "BlockType": "text",
              "Source": "<{Penalty.Description}>",
              "FontName": "Arial",
              "FontSize": 36,
              "Foreground": "#333333",
              "HorizontalAlignment": "Left",
              "TextOptions": { "Wrap": true }
            }
          ]
        },
        // Stewards Verdict Paragraph
        {
          "BlockType": "stack",
          "MarginTop": 60,
          "Orientation": "Vertical",
          "Items": [
            {
              "BlockType": "text",
              "Source": "STEWARDS VERDICT",
              "FontName": "Arial",
              "FontSize": 32,
              "Foreground": "#C9A84C",
              "HorizontalAlignment": "Left",
              "MarginBottom": 12
            },
            {
              "BlockType": "text",
              "Source": "<{Penalty.Verdict}>",
              "FontName": "Arial",
              "FontSize": 36,
              "Foreground": "#333333",
              "HorizontalAlignment": "Left",
              "TextOptions": { "Wrap": true }
            }
          ]
        },
        //the stewards
        {
          "BlockType": "text",
          "Source": "[FIASignature]",
          "MarginTop": 75,
          "MarginBottom": 75,
          "MarginLeft": 50,
          "FontName": "{FIAFontBold}",
          "Foreground": "{FIAText}",
          "FontSize": "{FIAFontSize}"
        }
      ]
    }
  ]
}
